From 9d1bcc2f78cdeef1751a6e281b255ebfc05604bb Mon Sep 17 00:00:00 2001
From: Felix Schlepper <felix.schlepper@cern.ch>
Date: Wed, 4 Mar 2026 12:54:24 +0100
Subject: [PATCH] add compression study

Signed-off-by: Felix Schlepper <felix.schlepper@cern.ch>
---
 ClusterCompressionStudy.sh | 33 +++++++++++++++++++++++++++++++++
 brotli.sh                  | 22 ++++++++++++++++++++++
 snappy.sh                  | 24 +++++++++++++++++++-----
 zstd.sh                    | 22 ++++++++++++++++++++++
 4 files changed, 96 insertions(+), 5 deletions(-)
 create mode 100644 ClusterCompressionStudy.sh
 create mode 100644 brotli.sh
 create mode 100644 zstd.sh

diff --git a/ClusterCompressionStudy.sh b/ClusterCompressionStudy.sh
new file mode 100644
index 00000000..aa35868b
--- /dev/null
+++ b/ClusterCompressionStudy.sh
@@ -0,0 +1,33 @@
+package: ClusterCompressionStudy
+version: main
+source: https://github.com/f3sch/ClusterCompressionStudy
+build_requires:
+- zstd
+- zlib
+- lz4
+- snappy
+- brotli
+- CMake
+- "GCC-Toolchain:(?!osx)"
+- alibuild-recipe-tools
+---
+#!/bin/bash -ex
+
+cmake -S "${SOURCEDIR}" -B "$BUILDDIR" \
+    -DCMAKE_BUILD_TYPE=Release \
+    -DCMAKE_BUILD_TYPE="$CMAKE_BUILD_TYPE" \
+    -DCMAKE_INSTALL_PREFIX="$INSTALLROOT"
+cmake --build . -- ${JOBS:+-j$JOBS}
+cmake --install .
+
+# install the compilation database so that we can post-check the code
+DEVEL_SOURCES="$(readlink "$SOURCEDIR" || echo $SOURCEDIR)"
+if [ "$DEVEL_SOURCES" != "$SOURCEDIR" ]; then
+    perl -p -i -e "s|$SOURCEDIR|$DEVEL_SOURCES|" compile_commands.json
+    ln -sf "$BUILDDIR"/compile_commands.json $DEVEL_SOURCES/compile_commands.json
+fi
+
+mkdir -p etc/modulefiles
+alibuild-generate-module >etc/modulefiles/$PKGNAME
+MODULEDIR="$INSTALLROOT/etc/modulefiles"
+mkdir -p "$MODULEDIR" && rsync -a --delete etc/modulefiles/ "$MODULEDIR"
